    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--coral);
    margin: 0 0 0.6rem 0;
  }
  .ha-roadmap-col ul {
    list-style: none;
