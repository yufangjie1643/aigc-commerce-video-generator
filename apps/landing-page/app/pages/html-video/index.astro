/*
 * Derived copy for the 16 non-authored locales: start from EN and overlay a
 * keyword-stacked, machine-derivable shell built from shared i18n fragments.
 * Same approach as derivedHtmlAnythingCopy — the head terms (HTML to video,
 * Hyperframes) stay in the title/description so SEO holds even before a full
 * human translation lands.
 */
function derivedHtmlVideoCopy(locale: LandingLocaleCode): HtmlVideoCopy {
  if (locale === DEFAULT_LOCALE) return HTML_VIDEO_COPY_EN;
  if (locale === 'zh') return HTML_VIDEO_COPY_ZH;

  const ui = getLandingUiCopy(locale);
  const product = getHeaderProductMenuCopy(locale);

  return {
    ...HTML_VIDEO_COPY_EN,
    title: SEO_TITLE[locale] ?? SEO_TITLE.en,
    label: product.product,
    heading: product.htmlVideoBlurb,
    description: `${product.htmlVideoBlurb} HTML → MP4 · Hyperframes · ffmpeg. ${HTML_VIDEO_COPY_EN.description}`,
    lead: `${product.htmlVideoBlurb} ${ui.footer.agents} CLI · Hyperframes · MP4.`,
  };
}

function formatCount(count: unknown): string | null {
  if (typeof count !== 'number' || !Number.isFinite(count) || count <= 0) return null;
  if (count < 1000) return String(count);
  return `${(count / 1000).toFixed(1).replace(/\.0$/, '')}K`;
}

let starsLabel = FALLBACK_STARS;
let licenseLabel = FALLBACK_LICENSE;

try {
  const response = await fetch(HV_REPO_API, {
    headers: { Accept: 'application/vnd.github+json' },
  });
  if (response.ok) {
    const repo = (await response.json()) as {
      stargazers_count?: number;
      license?: { spdx_id?: string };
    };
    starsLabel = formatCount(repo.stargazers_count) ?? starsLabel;
    licenseLabel = repo.license?.spdx_id ?? licenseLabel;
  }
} catch {
  // Network unavailable at build time — keep fallbacks.
}

