    gap: 0.5rem;
  }
  .ha-agents li {
    border: 1px solid var(--line);
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--ink-soft);
