<style>
  /* Page-local styles. Uses Open Design's global tokens from globals.css
   * (--serif / --mono / --ink / --coral / --line …) so this page stays in the
   * same visual system as the HTML Anything and Solutions pages. Spacing
   * rhythm follows taste-skill: consistent section gaps, tight title→content,
   * hairline dividers to group instead of large empty gaps. */

  /* ---- CTA buttons ---- */
  .ha-cta {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .ha-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border: 1px solid var(--ink);
    border-radius: 999px;
    font-size: 0.9rem;
    line-height: 1;
    white-space: nowrap;
    text-decoration: none;
    color: var(--ink);
    transition: background 0.15s ease, color 0.15s ease, transform 0.1s ease;
  }
  .ha-btn:hover { background: var(--ink); color: var(--paper); }
  .ha-btn:active { transform: translateY(1px); }
  .ha-btn-primary { background: var(--ink); color: var(--paper); }
  .ha-btn-primary:hover { background: var(--coral); border-color: var(--coral); color: #fff; }

  /* ---- Hero figure (kept restrained per taste-skill hero discipline) ---- */
  .ha-hero-figure {
    margin: 1.25rem 0 0 0;
    padding: 0;
  }
  .ha-hero-figure img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--line);
  }

  /* ---- At-a-glance stat band ---- */
  .ha-glance {
    margin: 2.25rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 1.25rem 0;
  }
  .ha-glance ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1.25rem 1.75rem;
  }
  .ha-glance li {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .ha-glance .num {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.9rem;
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .ha-glance .lbl {
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-mute);
  }
  /* ---- Section rhythm: single-edge top margin so adjacent sections sit at a
     consistent 2.25rem, never a doubled gap ---- */
  .ha-section { margin: 0; padding-top: 2.25rem; }
  .ha-h2 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.018em;
    color: var(--ink);
    margin: 0 0 0.75rem 0;
  }
  .ha-section-lead {
    max-width: 62ch;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 1.5rem 0;
  }

  /* ---- Ideas / engines: bordered cards on hairline grid ---- */
  .ha-ideas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .ha-idea {
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 1.25rem 1.35rem;
    background: var(--paper-warm);
  }
  .ha-idea h3 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.15rem;
    line-height: 1.25;
    color: var(--ink);
    margin: 0 0 0.5rem 0;
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    flex-wrap: wrap;
  }
  .ha-idea p { margin: 0; font-size: 0.95rem; line-height: 1.55; color: var(--ink-soft); }
  .ha-tag {
    font-family: var(--mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: var(--coral);
    color: #fff;
    white-space: nowrap;
  }

  /* ---- How-it-works numbered flow ---- */
  .ha-flow {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
  }
  .ha-flow li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.25rem 1.25rem;
    padding: 1.1rem 0;
    border-top: 1px solid var(--line);
