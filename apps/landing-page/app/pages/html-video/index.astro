  /* ---- Lightweight two-up notes (soundtrack / quickstart) ---- */
  .ha-duo {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .ha-note {
    border-left: 2px solid var(--coral);
