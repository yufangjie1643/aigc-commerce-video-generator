    glanceAria: ui.plugins.previewAndFacts,
    glance: {
      stars: 'GitHub',
      agents: `${ui.footer.agents} CLI`,
      templates,
      modes: ui.plugins.surfaces,
      license: ui.plugins.facts.license,
      foot: (date) => `${date} · GitHub / API`,
