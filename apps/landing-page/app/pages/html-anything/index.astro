      { headline: `${ui.footer.agents} / CLI`, body: `${summary} Claude Code / Codex / Cursor / Gemini / OpenCode / Qwen / Aider.` },
      { headline: `${skills} / SKILL.md`, body: `${templates} / SKILL.md / HTML / PNG.` },
