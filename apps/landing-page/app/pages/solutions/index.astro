---
/*
 * /solutions/ — Solution hub / overview page.
 *
 * The Solution nav trigger links here. It's an index of every Solution
 * sub-page, split into the same two groups the dropdown uses: Use cases
 * (what you're making) and Roles (who you are). Each card's title and blurb
 * reuse that sub-page's own breadcrumb + description from
 * getSolutionPageCopy, so the hub never drifts from the pages it links to.
 */
import Layout from '../../_components/sub-page-layout.astro';
import { getInfoPageCopy } from '../../info-page-i18n';
import { getSolutionPageCopy } from '../../solution-pages-i18n';
import { getSolutionsIndexCopy } from '../../solutions-index-i18n';
import { getCommonCopy, localeFromPath, localizedHref } from '../../i18n';
import type { SolutionPageKey } from '../../solution-pages-i18n/types';

const SITE = Astro.site?.toString() ?? 'https://open-design.ai/';
const locale = localeFromPath(Astro.url.pathname);
const href = (path: string) => localizedHref(path, locale);
const common = getInfoPageCopy(locale).common;
const page = getSolutionsIndexCopy(locale);
const nav = getCommonCopy(locale).header.nav;

// Each entry: the solution-page copy key (drives the localized title/blurb)
// and the route slug under /solutions/. Keep the two groups aligned with the
// header dropdown's SOLUTION_USE_CASES / SOLUTION_ROLES order.
type Entry = { key: SolutionPageKey; slug: string };

const USE_CASES: ReadonlyArray<Entry> = [
  { key: 'prototype', slug: 'prototype' },
  { key: 'dashboard', slug: 'dashboard' },
  { key: 'slides', slug: 'slides' },
  { key: 'image', slug: 'image' },
  { key: 'video', slug: 'video' },
  { key: 'designSystem', slug: 'design-system' },
];

const ROLES: ReadonlyArray<Entry> = [
  { key: 'roleSoloBuilder', slug: 'solo-builder' },
  { key: 'roleDesigner', slug: 'designer' },
  { key: 'roleEngineering', slug: 'engineering' },
  { key: 'roleProductManagers', slug: 'product-managers' },
  { key: 'roleMarketing', slug: 'marketing' },
];

const toCard = ({ key, slug }: Entry) => {
  const copy = getSolutionPageCopy(locale, key);
  return {
    slug,
    title: copy.breadcrumb,
    blurb: copy.description,
    href: href(`/solutions/${slug}/`),
  };
};

const useCaseCards = USE_CASES.map(toCard);
const roleCards = ROLES.map(toCard);

const title = page.heading;
const description = page.lead;

// ItemList JSON-LD enumerating every linked sub-page, so the hub is
// crawlable as a collection rather than a dead-end overview.
const allCards = [...useCaseCards, ...roleCards];
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Open Design', item: SITE },
      { '@type': 'ListItem', position: 2, name: page.heading, item: `${SITE}solutions/` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: `${SITE}solutions/`,
    isPartOf: { '@id': `${SITE}#website` },
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: allCards.map((c, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: c.title,
        url: new URL(c.href, SITE).toString(),
      })),
    },
  },
];
---

<Layout title={title} description={description} active="solution" jsonLd={jsonLd}>
  <nav class="breadcrumb" aria-label={common.breadcrumbAria}>
    <a href={href('/')}>Open Design</a>
    <span>/</span>
    <span aria-current="page">{page.heading}</span>
  </nav>

  <article class="info-page">
    <header class="catalog-head">
      <span class="label">{page.label}</span>
      <h1 class="display">{page.heading}</h1>
      <p class="lead">{page.lead}</p>
    </header>

    <section class="info-section" aria-labelledby="use-cases-heading">
      <h2 id="use-cases-heading">{nav.useCases}</h2>
      <ul class="compare-grid">
        {useCaseCards.map((c) => (
          <li class="compare-card">
            <h3>{c.title}</h3>
            <p>{c.blurb}</p>
            <a href={c.href}>{c.title} →</a>
          </li>
        ))}
      </ul>
    </section>

    <section class="info-section" aria-labelledby="roles-heading">
      <h2 id="roles-heading">{nav.roles}</h2>
      <ul class="compare-grid">
        {roleCards.map((c) => (
          <li class="compare-card">
            <h3>{c.title}</h3>
            <p>{c.blurb}</p>
            <a href={c.href}>{c.title} →</a>
          </li>
        ))}
      </ul>
    </section>
  </article>
</Layout>
