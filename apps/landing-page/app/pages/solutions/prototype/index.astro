---
/*
 * /solutions/prototype/ — Solution use-case page: prototyping with Open Design.
 *
 * This is the TEMPLATE the other five use-case pages copy. Layout is a wide,
 * Figma-marketing-style flow: a two-column hero band, a compact how-it-works
 * list, a capability table, a feature grid of REAL prototype-category plugins
 * (rendered via <TemplateCard>, same as image/video/slides), and an FAQ — all
 * responsive and scoped via `.solution-page` so the other info-pages keep
 * their narrow measure. Copy lives in `solution-pages-i18n.ts` (English +
 * Simplified Chinese; other locales fall back to English).
 */
import Layout from '../../../_components/sub-page-layout.astro';
import LazyImg from '../../../_components/lazy-img.astro';
import TemplateCard from '../../../_components/template-card.astro';
import { getInfoPageCopy } from '../../../info-page-i18n';
import { getSolutionPageCopy } from '../../../solution-pages-i18n';
import { getBundledPlugins } from '../../../_lib/bundled-plugins';
import { bundledRecordOf, categorizePlugin } from '../../../_lib/plugin-facets';
import { pickSolutionPlugins } from '../../../_lib/solution-featured';
import { imageAsset, imageAssetSrcset } from '../../../image-assets';
import { localeFromPath, localizedHref, localePath, stripLocaleFromPath } from '../../../i18n';

const SITE = Astro.site?.toString() ?? 'https://open-design.ai/';
const REPO = 'https://github.com/nexu-io/open-design';
const REPO_RELEASES = `${REPO}/releases`;
const locale = localeFromPath(Astro.url.pathname);
const href = (path: string) => localizedHref(path, locale);
const common = getInfoPageCopy(locale).common;
const page = getSolutionPageCopy(locale, 'prototype');

const title = page.title;
const description = page.description;

const heroImg = imageAsset('solutions/prototype/hero.png', { width: 1280, quality: 82 });
const heroSrcset = imageAssetSrcset('solutions/prototype/hero.png', [768, 1280]);

// Real prototype-category plugins for the feature grid (same <TemplateCard>
// path image/video/slides use, so previews resolve to pipeline-generated
// /previews/plugins/<manifest-id>.png). pickSolutionPlugins throws if any id
// is missing, so a renamed/removed plugin fails the build instead of
// silently shipping a short grid.
const FEATURED_PROTOTYPE_IDS = [
  'example-web-prototype',
  'example-mobile-app',
  'example-saas-landing',
  'example-gamified-app',
  'example-hr-onboarding',
  'example-kami-landing',
];
const allPrototypes = getBundledPlugins().filter(
  (p) => categorizePlugin(bundledRecordOf(p)) === 'prototype',
);
const featuredPrototypes = pickSolutionPlugins(allPrototypes, FEATURED_PROTOTYPE_IDS, 'prototype');

// Locale-aware page URL for JSON-LD so /ja/, /de/, … emit their own canonical
// rather than the English one (the layout's <link rel=canonical> is localized).
const pagePath = localePath(locale, stripLocaleFromPath(Astro.url.pathname).pathname);
const pageUrl = new URL(pagePath, SITE).toString();

const faq = page.faq;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Open Design', item: SITE },
      { '@type': 'ListItem', position: 2, name: page.breadcrumb, item: pageUrl },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: pageUrl,
    isPartOf: { '@id': `${SITE}#website` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map(({ q, a }) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: { '@type': 'Answer', text: a },
    })),
  },
];
---

<Layout title={title} description={description} active="solution" jsonLd={jsonLd}>
  <nav class="breadcrumb" aria-label={common.breadcrumbAria}>
    <a href={href('/')}>Open Design</a>
    <span>/</span>
    <span aria-current="page">{page.breadcrumb}</span>
  </nav>

  <article class="info-page solution-page">
    <div class="solution-hero-band">
      <header class="catalog-head">
        <span class="label">{page.label}</span>
        <h1 class="display">{page.heading}</h1>
        <p class="lead">{page.lead}</p>
        <div class="solution-hero-cta">
          <a class="btn btn-primary" href={REPO} target="_blank" rel="noreferrer noopener">{common.starOnGithub}</a>
          <a class="btn btn-ghost" href={href('/download/')}>{common.downloadDesktop}</a>
        </div>
      </header>
      <figure class="solution-hero">
        <LazyImg
          src={heroImg}
          srcset={heroSrcset}
          sizes="(max-width: 880px) 100vw, 540px"
          alt={page.heroImageAlt}
          loading="priority"
          width={1280}
          height={853}
        />
      </figure>
    </div>

    <div class="tldr-card">
      <h3>{page.tldrTitle}</h3>
      <p>{page.tldrBody}</p>
    </div>

    <section class="info-section" id="how">
      <h2>{page.stepsTitle}</h2>
      <ol class="solution-steps">
        {page.steps.map((step, idx) => (
          <li class="solution-step">
            <span class="solution-step-index">{String(idx + 1).padStart(2, '0')}</span>
            <div class="solution-step-text">
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="info-section catalog-grid templates-grid" id="features">
      <h2>{page.featuresTitle}</h2>
      <ul class="tpl-grid solution-tpl-grid">
        {featuredPrototypes.map((record, idx) => (
          <TemplateCard record={record} index={idx} />
        ))}
      </ul>
    </section>

    <section class="info-section" id="compare">
      <h2>{page.tableTitle}</h2>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th>{page.tableColCapability}</th>
              <th>{page.tableColWithOd}</th>
              <th>{page.tableColWithout}</th>
            </tr>
          </thead>
          <tbody>
            {page.tableRows.map((row) => (
              <tr>
                <th scope="row">{row.capability}</th>
                <td class="yes"><span class="check">●</span>{row.withOd}</td>
                <td>{row.without}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="info-section" id="browse">
      <p>{page.galleryLead}</p>
      <p>
        <a class="inline-link" href={href(page.exampleHref)}>{page.exampleLinkLabel} →</a>
      </p>
    </section>

    <section class="info-section" id="faq">
      <h2>{page.faqTitle}</h2>
      <ol class="faq-list">
        {faq.map(({ q, a }, idx) => (
          <li class="faq-item">
            <details>
              <summary>
                <span class="faq-index">{String(idx + 1).padStart(2, '0')}</span>
                <span class="faq-q">{q}</span>
                <span class="faq-toggle" aria-hidden="true">+</span>
              </summary>
              <p class="faq-a">{a}</p>
            </details>
          </li>
        ))}
      </ol>
    </section>

    <section class="info-cta" aria-label="Open Design call to action">
      <div>
        <h2>{page.ctaTitle}</h2>
        <p>{page.ctaBody}</p>
      </div>
      <div class="info-cta-actions">
        <a class="btn btn-primary" href={REPO} target="_blank" rel="noreferrer noopener">{common.starOnGithub}</a>
        <a class="btn btn-ghost" href={REPO_RELEASES} target="_blank" rel="noreferrer noopener">{common.downloadDesktop}</a>
      </div>
      <div class="info-cta-meta">
        <span class="stamp">● {common.apache}</span>
        <span>{common.localFirst} · {common.byok}</span>
        <span>{common.macWinLinux}</span>
      </div>
    </section>
  </article>
</Layout>
